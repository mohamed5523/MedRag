# OpenAI Configuration (used for LLM, GPT TTS, and judge)
OPENAI_API_KEY=your-openai-api-key

# Groq Configuration (used for Groq Whisper ASR — default ASR provider)
GROQ_API_KEY=your-groq-api-key

# ASR Provider: "groq" (default / Groq Whisper) | "elevenlabs" (legacy)
ASR_PROVIDER=groq
GROQ_WHISPER_MODEL=whisper-large-v3

# TTS provider: "openai" (default / GPT TTS) | "azure" | "elevenlabs" (legacy)
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_AUDIO_FORMAT=mp3

# Database Configuration
CHROMA_DB_PATH=./data/chroma_db

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true