# OpenAI Configuration (used for LLM, GPT TTS, and judge)
OPENAI_API_KEY=your-openai-api-key

# Groq Configuration (used for Groq Whisper ASR — default ASR provider)
GROQ_API_KEY=your-groq-api-key

# ASR Provider: "groq" (default / Groq Whisper) | "elevenlabs" (legacy)
ASR_PROVIDER=groq
GROQ_WHISPER_MODEL=whisper-large-v3

# TTS provider: "openai" (default / GPT TTS) | "azure" | "elevenlabs" (legacy)
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_AUDIO_FORMAT=mp3

# ElevenLabs TTS (legacy / alternative)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL=eleven_multilingual_v2

# Azure TTS (alternative)
AZURE_TTS_API_KEY=your-azure-tts-key
AZURE_TTS_ENDPOINT=https://your-region.cognitiveservices.azure.com/
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=ar-EG-SalmaNeural

# Database Configuration
CHROMA_DB_PATH=./data/chroma_db

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Timezone (for localized datetime responses)
DEFAULT_TZ=Africa/Cairo

# Clinic API (MCP Server)
CLINIC_PROVIDER_LIST_URL=http://your-clinic-api/api/clinicProviderlist/
CLINIC_PROVIDER_SCHEDULE_URL=http://your-clinic-api/api/clinicProviderschedule/
CLINIC_SERVICE_PRICE_URL=http://your-clinic-api/api/servicePrice/
CLINIC_API_USERNAME=your-username
CLINIC_API_PASSWORD=your-password
REQUEST_TIMEOUT=30
MAX_RETRIES=3
REQUEST_RETRY_BACKOFF=0.5

# ──────────────────────────────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta) — see docs/whatsapp_setup.md for full setup guide
# ──────────────────────────────────────────────────────────────────────────────
#
# WHATSAPP_TOKEN:
#   The Bearer token used to call the Meta Graph API.
#   ⚠️  Dev tokens from Meta's App Dashboard expire every 24 hours.
#   ✅  For production, use a permanent System User token from Meta Business Manager.
#       See docs/whatsapp_setup.md → "Get a Permanent Token"
#
WHATSAPP_TOKEN=your-permanent-system-user-token

# Phone Number ID from WhatsApp > API Setup in the Meta App Dashboard
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Any secret string you choose — must match what you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token

# Feature flags (set to "false" to disable)
ENABLE_PENDING_ACTION=true
ENABLE_SYMPTOM_TRIAGE=true